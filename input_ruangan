<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Input Peminjaman Ruangan</title>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 p-6" x-data="roomForm()">
    <div class="max-w-3xl mx-auto bg-white p-8 rounded-2xl shadow">
        <div class="flex justify-between items-center mb-6">
            <h2 class="text-xl font-bold">Form Peminjaman Ruangan</h2>
            <a href="daftar_ruangan.html" class="text-gray-400 text-2xl">&times;</a>
        </div>
        
        <form @submit.prevent="submit" class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="md:col-span-2">
                <label class="text-xs font-bold uppercase">Unit Peminjam</label>
                <select x-model="f.unit_peminjam" class="w-full border p-2 rounded">
                    <option>Karyawan</option>
                    <option>Peserta Didik</option>
                    <option>Instansi Luar</option>
                </select>
            </div>
            <div class="md:col-span-2">
                <label class="text-xs font-bold uppercase">Judul Acara</label>
                <input type="text" x-model="f.judul_acara" required class="w-full border p-2 rounded">
            </div>
             <div>
                <label class="text-xs font-bold uppercase">Nama</label>
                <input type="text" x-model="f.nama" required class="w-full border p-2 rounded">
            </div>
             <div>
                <label class="text-xs font-bold uppercase">Tanggal (Pilih)</label>
                <input type="date" @change="d => f.tanggal.push(d.target.value)" class="w-full border p-2 rounded">
                <div class="flex gap-1 mt-2 flex-wrap">
                    <template x-for="(t,i) in f.tanggal">
                        <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs">
                            <span x-text="t"></span>
                            <button type="button" @click="f.tanggal.splice(i,1)" class="ml-1 text-red-500">x</button>
                        </span>
                    </template>
                </div>
            </div>
            <div class="md:col-span-2">
                <button type="submit" class="w-full bg-green-600 text-white font-bold py-3 rounded-xl mt-4">KIRIM REQUEST</button>
            </div>
        </form>
    </div>

    <script>
        const SB_URL = "https://gyiucoognxykakksrulo.supabase.co";
        const SB_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imd5aXVjb29nbnh5a2Fra3NydWxvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzcyNjQ0MDQsImV4cCI6MjA5Mjg0MDQwNH0.Ht_yQbty5AaWYZWPp7sLWwIRDrmNs-LPot0NnVi3VIU";
        const _sb = supabase.createClient(SB_URL, SB_KEY);

        function roomForm() {
            return {
                f: { unit_peminjam: 'Karyawan', judul_acara: '', nama: '', tanggal: [], status: 'Request', nama_ruangan: 'Aula 1', jam_mulai: '08:00', jam_selesai: '09:00', identitas: '123' },
                async submit() {
                    const { error } = await _sb.from('peminjaman_ruangan').insert([this.f]);
                    if(!error) { alert('Berhasil!'); window.location.href='daftar_ruangan.html'; }
                    else { alert(error.message); }
                }
            }
        }
    </script>
</body>
</html>
